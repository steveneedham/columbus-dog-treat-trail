{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "ui_kits/map-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: status, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:verified|unverified|seasonal)$/]",
        "message": "<Badge> status must be one of 'verified' | 'unverified' | 'seasonal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Brand'] > JSXAttribute > JSXIdentifier[name!=/^(?:subtitle|logoSrc|key|ref|className|style|children)$/]",
        "message": "<Brand> doesn't accept that prop. Declared props: subtitle, logoSrc."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|icon|disabled|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, icon, disabled, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary)$/]",
        "message": "<Button> variant must be one of 'default' | 'primary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|color|icon|active|onClick|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: label, color, icon, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPin'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|status|seasonal|sponsored|size|key|ref|className|style|children)$/]",
        "message": "<MapPin> doesn't accept that prop. Declared props: color, status, seasonal, sponsored, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPin'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:verified|unverified)$/]",
        "message": "<MapPin> status must be one of 'verified' | 'unverified'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|ctaLabel|ctaHref|onClose|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, title, children, ctaLabel, ctaHref, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopupCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|typeLabel|neighborhood|status|seasonal|venue|notes|photoUrl|onMarkVerified|key|ref|className|style|children)$/]",
        "message": "<PopupCard> doesn't accept that prop. Declared props: name, typeLabel, neighborhood, status, seasonal, venue, notes, photoUrl, onMarkVerified."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopupCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:verified|unverified)$/]",
        "message": "<PopupCard> status must be one of 'verified' | 'unverified'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|kind|message|onClose|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: open, kind, message, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:success|error|info)$/]",
        "message": "<Toast> kind must be one of 'success' | 'error' | 'info'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
